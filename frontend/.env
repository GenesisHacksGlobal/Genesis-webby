REACT_APP_BACKEND_URL=http://localhost:8000
# Optional Formspree form id (https://formspree.io) — used when /api/contact has no provider
# REACT_APP_FORMSPREE_ID=
# Optional PostHog — only loads after cookie consent Accept
# REACT_APP_POSTHOG_KEY=
# REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
# Leave unset locally so HMR uses the same port as the app (3000).
# WDS_SOCKET_PORT=443 breaks local WebSocket (ERR_CONNECTION_REFUSED).
ENABLE_HEALTH_CHECK=false
